# TMDB — match API, posters, Claude backfill lookups
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Supabase catalog (default match source)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Claude rerank (optional but recommended when using energy sliders)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Match source: supabase (default) | tmdb
# MATCH_SOURCE=supabase

# Catalog Claude rerank: 1 (default) | 0 to disable
# CATALOG_CLAUDE_RERANK=1

# Always call Claude even for single-genre-only searches
# CATALOG_CLAUDE_ALWAYS=0

# claude-sonnet-4-5 (default) or claude-haiku-4-5 for lower cost
# CLAUDE_RERANK_MODEL=claude-sonnet-4-5
